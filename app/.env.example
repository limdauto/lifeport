# Convex (auto-set by `npx convex dev`)
# CONVEX_DEPLOYMENT=
# NEXT_PUBLIC_CONVEX_URL=

# App URL for Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Debug report previews at /debug (enabled automatically in development)
# NEXT_PUBLIC_ENABLE_DEBUG=true

# Stripe (optional — dev mock checkout used when unset)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# AI (optional — template generation used when unset)
# OPENAI_API_KEY=

# Admin + Convex backend vars live in .env.local (see .env.local.example).
# They sync to Convex automatically on `npm run dev`, or run `npm run sync:env`.
