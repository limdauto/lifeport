# Convex (auto-set by `npx convex dev`)
# CONVEX_DEPLOYMENT=
# NEXT_PUBLIC_CONVEX_URL=

# App URL for Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (optional — dev mock checkout used when unset)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# AI (optional — template generation used when unset)
# OPENAI_API_KEY=

# Admin (optional — when set, living reports require founder review before customer delivery)
# ADMIN_SECRET=your-secret-here
