# Copy to .env.local — used by Next.js and synced to Convex on `npm run dev`.
# CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL are auto-written by `npx convex dev`.

# --- Convex backend (synced on npm run dev) ---

# Convex Auth JWT keys — auto-generated on first `npm run dev` if missing
# JWT_PRIVATE_KEY=
# JWKS=

# Local dev admin sign-in (auto-seeded when using local Convex)
DEV_ADMIN_EMAIL=admin@lifeport.local
DEV_ADMIN_PASSWORD=lifeport-dev

# Comma-separated emails allowed to access /admin and debug toolbar
# ADMIN_EMAILS=admin@lifeport.local,you@company.com

# Founder review gate — when set, Lifeport Plans require review before delivery
# ADMIN_SECRET=your-secret-here

# Dev seed toggles (local Convex only unless ALLOW_DEV_ADMIN_SEED=true)
# ALLOW_DEV_ADMIN_SEED=true
# DISABLE_DEV_ADMIN_SEED=true

# Optional integrations
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Next.js client ---

NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_ENABLE_DEBUG=true
