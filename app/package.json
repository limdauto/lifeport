{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-auth-keys.mjs && node scripts/sync-convex-env.mjs",
    "dev": "convex dev --typecheck=disable --run devSeed:seedDevAdmin --start 'next dev -p 3000'",
    "sync:env": "node scripts/ensure-auth-keys.mjs && node scripts/sync-convex-env.mjs",
    "dev:next": "next dev -p 3000",
    "dev:convex": "npm run sync:env && convex dev --typecheck=disable --run devSeed:seedDevAdmin",
    "seed:admin": "npm run sync:env && convex run devSeed:seedDevAdmin",
    "verify": "node scripts/verify-flow.mjs",
    "verify:paid": "node scripts/verify-paid-flow.mjs",
    "verify:regen": "node scripts/verify-regen-flow.mjs",
    "verify:admin": "node scripts/verify-admin-flow.mjs",
    "build": "next build",
    "build:cf": "node scripts/prepare-cf-build.mjs && opennextjs-cloudflare build",
    "deploy:cf": "node scripts/prepare-cf-build.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:cf:only": "opennextjs-cloudflare deploy",
    "preview:cf": "node scripts/prepare-cf-build.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.80",
    "@opennextjs/cloudflare": "^1.19.11",
    "convex": "^1.40.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.98.0"
  }
}
