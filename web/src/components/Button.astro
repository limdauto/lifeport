---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'md' | 'sm';
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 font-semibold transition-colors rounded-DEFAULT';
const sizes = {
  md: 'px-6 py-3 text-label-md',
  sm: 'px-4 py-2 text-label-sm',
};
const variants = {
  primary: 'bg-primary text-on-primary hover:bg-primary-container',
  secondary:
    'bg-secondary-container text-on-secondary-fixed border-soft hover:bg-secondary-fixed',
  outline:
    'bg-surface-container-lowest text-primary border-soft hover:bg-surface-container-low',
};

const classes = `${base} ${sizes[size]} ${variants[variant]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes}>
  <slot />
</Tag>
