---
const riskItems = [
  { label: 'Tax Residency Transition', level: 'critical', bar: 'bg-error-container' },
  { label: 'Spouse Visa Processing', level: 'high', bar: 'bg-amber-100' },
  { label: 'Nursery Registration', level: 'high', bar: 'bg-amber-100' },
  { label: 'Bank Account Setup', level: 'low', bar: 'bg-surface-container' },
];

const levelStyles: Record<string, string> = {
  critical: 'bg-error-container text-on-error-container',
  high: 'bg-amber-200 text-amber-900',
  low: 'bg-surface-container-high text-on-surface-variant',
};

const levelLabels: Record<string, string> = {
  critical: 'Critical',
  high: 'High',
  low: 'Low',
};

const timeline = [
  {
    month: 'Month 1',
    status: 'active' as const,
    statusLabel: 'In progress',
    tasks: [
      { label: 'Visa Applications', done: true },
      { label: 'Document Apostille', done: false },
    ],
  },
  {
    month: 'Month 2',
    status: 'upcoming' as const,
    statusLabel: 'Upcoming',
    tasks: [
      { label: 'Tax Structuring', done: false },
      { label: 'Bank Account Setup', done: false },
    ],
  },
  {
    month: 'Month 3',
    status: 'upcoming' as const,
    statusLabel: 'Upcoming',
    tasks: [
      { label: 'Housing & Schooling', done: false },
      { label: 'Tax Registration', done: false },
    ],
  },
];

const nodeClass = {
  active: 'dashboard-timeline-node dashboard-timeline-node--active',
  upcoming: 'dashboard-timeline-node dashboard-timeline-node--upcoming',
};

const statusBadge = {
  active: 'bg-primary-fixed text-on-primary-fixed-variant',
  upcoming: 'bg-surface-container text-on-surface-variant',
};
---

<div class="dashboard-window">
  <div class="flex items-center justify-between border-b border-outline-variant/50 bg-surface-container-high px-6 py-4">
    <div class="flex items-center gap-3">
      <span class="text-label-md text-on-surface font-semibold">Lifeport Plan — sample pages</span>
    </div>
    <div class="flex gap-1.5" aria-hidden="true">
      <span class="h-2.5 w-2.5 rounded-full bg-outline-variant/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-outline-variant/60"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-outline-variant/60"></span>
    </div>
  </div>

  <div class="dashboard-window-body">
    <div class="grid gap-10 md:grid-cols-2">
      <div>
        <div class="flex items-baseline justify-between mb-5">
          <h4 class="text-label-md text-on-surface font-semibold">Risk Map</h4>
          <span class="text-label-sm text-outline">Updated today</span>
        </div>
        <ul class="space-y-3">
          {
            riskItems.map((item) => (
              <li
                class:list={[
                  'flex items-center justify-between rounded-DEFAULT px-4 py-3.5',
                  item.bar,
                ]}
              >
                <span class="text-body-md text-on-surface font-medium">{item.label}</span>
                <span
                  class:list={[
                    'rounded-full px-2.5 py-0.5 text-label-sm font-semibold uppercase tracking-wide',
                    levelStyles[item.level],
                  ]}
                >
                  {levelLabels[item.level]}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="rounded-lg bg-surface-container-low/60 p-5">
        <div class="flex items-baseline justify-between mb-5">
          <h4 class="text-label-md text-on-surface font-semibold">Timeline</h4>
          <span class="text-label-sm text-outline">3-month view</span>
        </div>

        <div class="dashboard-timeline">
          <div class="dashboard-timeline-track" aria-hidden="true"></div>
          {
            timeline.map((entry) => (
              <div class="dashboard-timeline-entry">
                <div class={nodeClass[entry.status]} aria-hidden="true"></div>

                <div class="flex flex-wrap items-center gap-2">
                  <p class="text-label-md text-on-surface font-semibold">{entry.month}</p>
                  <span
                    class:list={[
                      'rounded-full px-2 py-0.5 text-label-sm font-medium',
                      statusBadge[entry.status],
                    ]}
                  >
                    {entry.statusLabel}
                  </span>
                </div>

                <ul class="mt-3 space-y-2">
                  {entry.tasks.map((task) => (
                    <li
                      class:list={[
                        'dashboard-timeline-task',
                        task.done && 'dashboard-timeline-task--done',
                      ]}
                    >
                      <span
                        class:list={[
                          'flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-[10px] font-semibold',
                          task.done
                            ? 'bg-primary text-on-primary'
                            : 'border border-outline-variant text-outline',
                        ]}
                        aria-hidden="true"
                      >
                        {task.done ? '✓' : ''}
                      </span>
                      <span class={task.done ? 'font-medium text-on-surface' : ''}>{task.label}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>
