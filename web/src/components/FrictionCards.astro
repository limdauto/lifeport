---
const cards = [
  {
    icon: 'bank',
    title: 'Banking',
    points: ['Need local address to open account', '4-week processing delay'],
  },
  {
    icon: 'visa',
    title: 'Visa & Immig.',
    points: ['Apostille required for marriage cert', 'Spouse visa processing frozen'],
  },
  {
    icon: 'housing',
    title: 'Housing',
    points: ['Need bank account to sign lease', 'No local credit history'],
  },
  {
    icon: 'tax',
    title: 'Tax & Estate',
    points: ['Double taxation risk on assets', 'Current will invalid in destination'],
  },
  {
    icon: 'childcare',
    title: 'Childcare',
    points: ['School registration needs local address', 'Nurseries full 6 months in advance'],
  },
];

const icons: Record<string, string> = {
  bank: 'M3 10h18M5 10V8a2 2 0 012-2h10a2 2 0 012 2v2M5 10v8h14v-8M9 14h2M13 14h2',
  visa: 'M3 7h18v10H3V7zm3 3h12M7 13h4',
  housing: 'M3 12l9-7 9 7M5 10v9h14v-9M10 19v-5h4v5',
  tax: 'M9 7H7a2 2 0 00-2 2v9a2 2 0 002 2h10a2 2 0 002-2V9a2 2 0 00-2-2h-2M9 7V5a2 2 0 012-2h2a2 2 0 012 2v2',
  childcare: 'M12 4a4 4 0 100 8 4 4 0 000-8zm-8 14a8 8 0 0116 0',
};
---

<section class="section bg-surface-container-lowest">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-headline-lg text-on-surface">The Reality of Relocation</h2>
      <p class="text-body-lg text-on-surface-variant mt-4">
        Disconnected systems, conflicting timelines, and hidden friction points — most people only
        discover them when it's too late.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {
        cards.map((card) => (
          <article class="friction-card">
            <div class="flex items-start justify-between gap-2">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-DEFAULT bg-error-container/60 text-on-error-container">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={icons[card.icon]} />
                </svg>
              </div>
              <span class="friction-tag">Friction</span>
            </div>
            <h3 class="text-label-md text-on-surface mt-4">{card.title}</h3>
            <ul class="mt-3 space-y-2.5">
              {card.points.map((point) => (
                <li class="text-label-sm text-on-surface-variant flex gap-2 leading-snug">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-error" aria-hidden="true" />
                  {point}
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
