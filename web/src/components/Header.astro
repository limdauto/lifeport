---
import Button from './Button.astro';
import Logo from './Logo.astro';
import { PLAN_CTA, PLAN_CTA_HREF } from '../constants/copy';

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between md:h-20">
    <a href="/" class="transition-opacity hover:opacity-80">
      <Logo size="sm" />
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      <a
        href="/routes"
        class:list={[
          'text-body-md transition-colors',
          pathname.startsWith('/routes') || pathname === '/professionals'
            ? 'text-primary font-medium'
            : 'text-on-surface-variant hover:text-primary',
        ]}>Relocation Routes</a
      >
      <a
        href="/how-it-works"
        class:list={[
          'text-body-md transition-colors',
          pathname === '/how-it-works'
            ? 'text-primary font-medium'
            : 'text-on-surface-variant hover:text-primary',
        ]}>How It Works</a
      >
      <a
        href="/professionals"
        class:list={[
          'text-body-md transition-colors',
          pathname === '/professionals'
            ? 'text-primary font-medium'
            : 'text-on-surface-variant hover:text-primary',
        ]}>For Professionals</a
      >
      <a
        href="/pricing"
        class:list={[
          'text-body-md transition-colors',
          pathname === '/pricing'
            ? 'text-primary font-medium'
            : 'text-on-surface-variant hover:text-primary',
        ]}>Pricing</a
      >
    </nav>

    <Button href={PLAN_CTA_HREF} size="sm">{PLAN_CTA}</Button>
  </div>
</header>
