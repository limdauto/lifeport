---
import Button from './Button.astro';
---

<section id="hero" class="relative overflow-hidden">
  <div class="container-page section">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl">
        <span class="friction-tag">The Problem</span>
        <h1 class="text-display text-on-surface mt-6">
          Moving country breaks your life into pieces.
        </h1>
        <p class="text-body-lg text-on-surface-variant mt-6">
          Immigration, tax, banking, housing, schools — each lives in a different system. Lifeport
          organizes everything into one clear plan so nothing falls through the cracks.
        </p>
        <div class="mt-8">
          <Button href="#planner">Build my Lifeport Plan</Button>
        </div>
      </div>

      <div class="relative">
        <div class="overflow-hidden rounded-xl shadow-soft-lg">
          <img
            src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=800&h=600&fit=crop&q=80"
            alt="A couple looking out over a city skyline at sunset"
            class="aspect-[4/3] w-full object-cover"
            loading="eager"
            width="800"
            height="600"
          />
        </div>
        <div class="absolute -bottom-4 -left-4 hidden card !p-4 md:block" aria-hidden="true">
          <p class="text-label-sm text-on-surface-variant">Active plans</p>
          <p class="text-headline-md text-primary font-semibold">2,400+</p>
        </div>
      </div>
    </div>
  </div>
</section>
