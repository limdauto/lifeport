---
interface Props {
  size?: 'sm' | 'md';
}

const { size = 'md' } = Astro.props;
const iconSize = size === 'sm' ? 28 : 36;
---

<span class="flex items-center gap-2.5">
  <img
    src="/logo.png"
    alt=""
    width={iconSize}
    height={iconSize}
    class="shrink-0"
    aria-hidden="true"
  />
  <span class="text-headline-md font-semibold text-primary tracking-tight">Lifeport</span>
</span>
