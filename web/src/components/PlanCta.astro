---
import Button from './Button.astro';
import { PLAN_CTA, PLAN_CTA_HREF, PLAN_DELIVERY_NOTE } from '../constants/copy';

interface Props {
  class?: string;
  centered?: boolean;
  href?: string;
  label?: string;
}

const {
  class: className = '',
  centered = false,
  href = PLAN_CTA_HREF,
  label = PLAN_CTA,
} = Astro.props;
---

<div class:list={[centered && 'text-center', className]}>
  <Button href={href}>{label}</Button>
  <p class:list={['text-label-sm text-on-surface-variant mt-3', centered && 'mx-auto max-w-md']}>
    {PLAN_DELIVERY_NOTE}
  </p>
</div>
