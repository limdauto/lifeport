---
const features = [
  { title: 'Timeline', description: 'Unified move timeline with dependencies' },
  { title: 'Documents', description: 'Checklist of required paperwork' },
  { title: 'Visa & Admin', description: 'Immigration steps and deadlines' },
  { title: 'Banking', description: 'Account setup and transfer guidance' },
  { title: 'Tax Guidance', description: 'Residency and filing considerations' },
  { title: 'Housing', description: 'Lease requirements and guarantors' },
  { title: 'Healthcare', description: 'Insurance and registration steps' },
  { title: 'Family', description: 'Spouse and dependent considerations' },
  { title: 'Estate Planning', description: 'Wills and asset protection' },
  { title: 'Childcare & Schools', description: 'Enrollment and nursery planning' },
];
---

<section class="section bg-surface-container-low">
  <div class="container-page">
    <h2 class="text-headline-lg text-on-surface text-center">What your plan includes</h2>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-DEFAULT bg-tertiary-fixed text-primary">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <h3 class="text-label-md text-on-surface">{feature.title}</h3>
              <p class="text-body-md text-on-surface-variant mt-1">{feature.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
