---
import Button from './Button.astro';
import { PLAN_CTA_HREF } from '../constants/copy';
---

<section class="section bg-surface-container-low">
  <div class="container-page">
    <div class="pro-support-banner flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div class="max-w-2xl">
        <span class="planner-tag">Professional Support</span>
        <h2 class="text-headline-lg text-on-surface mt-6">
          Built for planning. Ready for experts.
        </h2>
        <p class="text-body-lg text-on-surface-variant mt-4">
          Your Lifeport Plan PDF is structured so lawyers, accountants, tax advisers, and relocation
          specialists can review the right information faster — no scattered notes or missing context.
        </p>
      </div>
      <Button href={PLAN_CTA_HREF} variant="outline" class="shrink-0">Order your plan</Button>
    </div>
  </div>
</section>
