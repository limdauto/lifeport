---
import Button from './Button.astro';
---

<section class="section bg-surface-container-low">
  <div class="container-page">
    <div class="pro-support-banner flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
      <div class="max-w-2xl">
        <span class="planner-tag">Professional Support</span>
        <h2 class="text-headline-lg text-on-surface mt-6">
          Built for planning. Ready for experts.
        </h2>
        <p class="text-body-lg text-on-surface-variant mt-4">
          Lifeport helps you prepare a structured move profile and expert packet, so lawyers,
          accountants, tax advisers, and relocation specialists can review the right information
          faster.
        </p>
      </div>
      <Button href="#" variant="outline" class="shrink-0">Learn about Expert Packets</Button>
    </div>
  </div>
</section>
