---
import Badge from '../Badge.astro';

interface Props {
  riskFlags: { title: string; description: string }[];
  protocols: { title: string; description: string }[];
}

const { riskFlags, protocols } = Astro.props;
---

<section class="section">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-headline-lg text-on-surface">Personal Infrastructure Protocols</h2>
      <p class="text-body-lg text-on-surface-variant mt-4">
        Systematic management of high-risk settlement failure points.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        riskFlags.map((flag) => (
          <article class="card overflow-hidden !p-0">
            <div class="bg-error-container/50 px-6 py-3 flex items-center gap-2">
              <span class="text-on-error-container text-sm" aria-hidden="true">⚑</span>
              <Badge variant="friction">Risk Flag</Badge>
            </div>
            <div class="p-6">
              <h3 class="text-label-md text-on-surface">{flag.title}</h3>
              <p class="text-body-md text-on-surface-variant mt-2">{flag.description}</p>
            </div>
          </article>
        ))
      }
      {
        protocols.map((proto) => (
          <article class="card">
            <h3 class="text-label-md text-on-surface">{proto.title}</h3>
            <p class="text-body-md text-on-surface-variant mt-2">{proto.description}</p>
          </article>
        ))
      }
      <article class="rounded-lg bg-primary p-8 text-on-primary shadow-soft sm:col-span-2 lg:col-span-1">
        <h3 class="text-label-md">First 90-day Plan</h3>
        <p class="text-body-md mt-2 opacity-90">
          A sequenced checklist for your critical first three months — prioritized by dependencies
          and deadlines.
        </p>
      </article>
    </div>
  </div>
</section>
