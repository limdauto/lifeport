---
import GapComparison from './GapComparison.astro';
import ProtocolsGrid from './ProtocolsGrid.astro';
import PlanCta from '../PlanCta.astro';
import type { RouteConfig } from '../../data/routes';

interface Props {
  route: RouteConfig;
}

const { route } = Astro.props;
---

<section class="section">
  <div class="container-page">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="max-w-xl">
        <span class="planner-tag">{route.badge}</span>
        <h1 class="text-display text-on-surface mt-4">{route.title}</h1>
        <p class="text-body-lg text-on-surface-variant mt-6">{route.description}</p>
        <div class="mt-8">
          <PlanCta />
        </div>
      </div>

      <div class="card shadow-soft-lg">
        <p class="text-label-md text-on-surface font-semibold">What your plan will cover</p>
        <p class="text-body-md text-on-surface-variant mt-2">
          A personalised PDF mapping your critical path, risk flags, and sequenced actions for this
          route.
        </p>
        <ul class="mt-6 space-y-3">
          {
            route.planCoverage.map((item) => (
              <li class="flex items-start gap-3 text-body-md text-on-surface-variant">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-6 overflow-hidden rounded-lg">
          <img
            src={route.image}
            alt={route.imageAlt}
            class="aspect-[2/1] w-full object-cover"
            width="500"
            height="280"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<GapComparison employerItems={route.employerItems} yourItems={route.yourItems} />

<ProtocolsGrid riskFlags={route.riskFlags} protocols={route.protocols} />

<section class="section bg-surface-container-low">
  <div class="container-page">
    <div class="pro-support-banner text-center">
      <h2 class="text-headline-lg text-on-surface">Ready for your plan?</h2>
      <p class="text-body-lg text-on-surface-variant mt-4 max-w-xl mx-auto">
        Tell us about your move and we'll prepare a personalised Lifeport Plan PDF for this route —
        timelines, dependencies, and expert-ready summaries included.
      </p>
      <div class="mt-8 flex justify-center">
        <PlanCta centered />
      </div>
    </div>
  </div>
</section>
