---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RouteLanding from '../components/sections/RouteLanding.astro';
import { getRoute } from '../data/routes';

const route = getRoute('professionals')!;
---

<Layout
  title="Lifeport — UK Arrival Plan for Professionals"
  description="Your company moves your job. Order a personalised Lifeport Plan PDF for your UK arrival — banking, tax, housing, and more."
>
  <Header />
  <main>
    <RouteLanding route={route} />
  </main>
  <Footer />
</Layout>
