---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SetupPackages from '../components/SetupPackages.astro';

const employerItems = [
  'Work Visa Application',
  'Initial Flights',
  'Corporate Tax Setup',
  'Office Access',
];

const yourItems = [
  'Bank Account',
  'Tax Residence',
  'Housing & Lease',
  'Healthcare Registration',
  'School Enrollment',
  'Estate Planning',
];

const riskFlags = [
  { title: 'Split-Year Tax Treatment', description: 'Potential dual-residency in transition year' },
  { title: 'Spouse Visa Dependency', description: 'Partner status tied to primary applicant' },
  { title: 'Nursery Waitlist Gap', description: '6-month lead time vs. arrival date' },
];

const protocols = [
  { title: 'Housing & Guarantors', description: 'Credit history and deposit requirements' },
  { title: 'NHS & Healthcare', description: 'Registration and family coverage steps' },
  { title: 'Banking Pre-approval', description: 'Account setup before lease signing' },
];

const checklist = [
  { label: 'Visa Documentation', done: true },
  { label: 'UK Banking Pre-approval', done: true },
  { label: 'Temporary Housing', done: false },
];

const dashboardTasks = [
  { label: 'Submit Biometric Appointment', status: 'urgent' },
  { label: 'Open UK Bank Account', status: 'due' },
  { label: 'Register with GP', status: 'pending' },
];
---

<Layout
  title="Lifeport — UK Arrival Plan for Professionals"
  description="Your company moves your job. Lifeport helps you move your life with a personalized UK arrival infrastructure plan."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="section">
      <div class="container-page">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="max-w-xl">
            <Badge>UK Arrival Route</Badge>
            <h1 class="text-display text-on-surface mt-4">
              Your company moves your job. You have to move your life.
            </h1>
            <p class="text-body-lg text-on-surface-variant mt-6">
              Lifeport builds your personalized infrastructure plan — banking, tax, housing,
              healthcare — so nothing falls through the gap between employer support and personal
              responsibility.
            </p>
            <div class="mt-8">
              <Button href="#planner">Build my UK arrival plan →</Button>
            </div>
          </div>

          <div class="card shadow-soft-lg">
            <p class="text-label-md text-on-surface">Arrival Plan Readiness</p>
            <div class="mt-4 h-2 overflow-hidden rounded-full bg-surface-container">
              <div class="h-full w-[85%] rounded-full bg-primary-fixed-dim" />
            </div>
            <p class="text-label-sm text-primary mt-2 font-semibold">85% Complete</p>
            <ul class="mt-6 space-y-3">
              {
                checklist.map((item) => (
                  <li class="flex items-center gap-3 text-body-md">
                    <span
                      class:list={[
                        'flex h-5 w-5 items-center justify-center rounded-full text-xs',
                        item.done
                          ? 'bg-primary-fixed text-primary'
                          : 'border border-outline-variant text-outline',
                      ]}
                    >
                      {item.done ? '✓' : ''}
                    </span>
                    <span class={item.done ? 'text-on-surface' : 'text-on-surface-variant'}>
                      {item.label}
                    </span>
                  </li>
                ))
              }
            </ul>
            <div class="mt-6 overflow-hidden rounded-lg">
              <img
                src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?w=400&h=200&fit=crop&q=80"
                alt="London skyline"
                class="aspect-[2/1] w-full object-cover"
                width="400"
                height="200"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Gap -->
    <section class="section bg-surface-container-low">
      <div class="container-page">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-headline-lg text-on-surface">The Gap: What your employer doesn't handle</h2>
          <p class="text-body-lg text-on-surface-variant mt-4">
            Corporate relocation covers the job. Everything else — your family's life infrastructure
            — is on you.
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-2">
          <div class="card">
            <h3 class="text-label-md text-on-surface-variant uppercase tracking-wide">
              Employer Support
            </h3>
            <ul class="mt-6 space-y-3">
              {
                employerItems.map((item) => (
                  <li class="flex items-center gap-3 text-body-md text-on-surface-variant">
                    <span class="text-outline">✓</span>
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="card border-soft !shadow-soft-lg ring-1 ring-primary/20">
            <h3 class="text-label-md text-primary uppercase tracking-wide">Your Responsibility</h3>
            <ul class="mt-6 space-y-3">
              {
                yourItems.map((item) => (
                  <li class="flex items-center gap-3 text-body-md text-on-surface">
                    <svg
                      class="h-4 w-4 shrink-0 text-primary"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M12 2L2 22h20L12 2z" />
                    </svg>
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Protocols -->
    <section class="section">
      <div class="container-page">
        <div class="max-w-2xl">
          <h2 class="text-headline-lg text-on-surface">Personal Infrastructure Protocols</h2>
          <p class="text-body-lg text-on-surface-variant mt-4">
            Settlement failure points mapped before they become crises.
          </p>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            riskFlags.map((flag) => (
              <article class="card overflow-hidden !p-0">
                <div class="bg-error-container/50 px-6 py-3 flex items-center gap-2">
                  <span class="text-on-error-container text-sm">⚑</span>
                  <Badge variant="friction">Risk Flag</Badge>
                </div>
                <div class="p-6">
                  <h3 class="text-label-md text-on-surface">{flag.title}</h3>
                  <p class="text-body-md text-on-surface-variant mt-2">{flag.description}</p>
                </div>
              </article>
            ))
          }
          {
            protocols.map((proto) => (
              <article class="card">
                <h3 class="text-label-md text-on-surface">{proto.title}</h3>
                <p class="text-body-md text-on-surface-variant mt-2">{proto.description}</p>
              </article>
            ))
          }
          <article class="rounded-lg bg-primary p-8 text-on-primary shadow-soft sm:col-span-2 lg:col-span-1">
            <h3 class="text-label-md">First 90-day Plan</h3>
            <p class="text-body-md mt-2 opacity-90">
              A sequenced checklist for your critical first three months — prioritized by
              dependencies and deadlines.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Expert Planner -->
    <section id="planner" class="bg-white py-20">
      <div class="container-page">
        <div class="grid items-center gap-12 lg:grid-cols-2">
          <div class="rounded-xl bg-inverse-surface p-8 font-mono text-sm text-inverse-on-surface shadow-soft-lg">
            <div class="flex items-center justify-between border-b border-outline-variant/30 pb-4">
              <span class="text-primary-fixed-dim">ARRIVAL_CTRL // UK_SKILLED_WORKER</span>
              <span class="rounded bg-error-container px-2 py-0.5 text-label-sm text-on-error-container">
                T-MINUS: 14 DAYS
              </span>
            </div>
            <div class="mt-4 flex gap-4 text-label-sm">
              <span class="text-primary-fixed-dim">STATUS: ACTIVE</span>
              <span class="text-on-error-container">CRITICAL_PATH: 2 BLOCKED</span>
            </div>
            <ul class="mt-6 space-y-3">
              {
                dashboardTasks.map((task) => (
                  <li class="flex items-center justify-between rounded bg-surface-container-high/20 px-4 py-2">
                    <span>{task.label}</span>
                    <span
                      class:list={[
                        'rounded px-2 py-0.5 text-label-sm uppercase',
                        task.status === 'urgent'
                          ? 'bg-error-container text-on-error-container'
                          : task.status === 'due'
                            ? 'bg-amber-200/20 text-amber-200'
                            : 'bg-surface-container-high/30 text-surface-container',
                      ]}
                    >
                      {task.status === 'urgent' ? 'Urgent' : task.status === 'due' ? 'Due: <24h' : 'Pending'}
                    </span>
                  </li>
                ))
              }
            </ul>
            <div class="mt-6 rounded border border-error/50 bg-error-container/10 p-4">
              <p class="text-label-sm font-semibold text-on-error-container">
                SYSTEM WARNING: TAX BOUNDARY
              </p>
              <p class="text-label-sm text-surface-container mt-1">
                Split-year treatment may apply. Review tax residence packet.
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-headline-lg text-on-surface">The Expert-Ready Planner</h2>
            <p class="text-body-lg text-on-surface-variant mt-4">
              Precision planning that maps dependencies, flags risks, and prepares structured packets
              your lawyer or accountant can act on immediately.
            </p>
            <p class="text-body-md text-on-surface-variant mt-6 italic">
              Lifeport is not a replacement for regulated legal, tax, or financial advice.
            </p>
          </div>
        </div>
      </div>
    </section>

    <SetupPackages />
  </main>
  <Footer />
</Layout>
