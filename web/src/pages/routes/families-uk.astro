---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RouteLanding from '../../components/sections/RouteLanding.astro';
import { getRoute } from '../../data/routes';

const route = getRoute('families-uk')!;
---

<Layout
  title="Lifeport — Families Moving to the UK"
  description="Order a personalised Lifeport Plan PDF for families moving to the UK — schools, visas, nurseries, and housing dependencies mapped."
>
  <Header />
  <main>
    <RouteLanding route={route} />
  </main>
  <Footer />
</Layout>
